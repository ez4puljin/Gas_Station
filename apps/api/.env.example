# ── API (NestJS + Prisma) — apps/api/.env ──
# Заавал: DATABASE_URL, REDIS_URL, JWT_ACCESS_SECRET, JWT_REFRESH_SECRET. Бусад нь default-тай.

NODE_ENV=development
API_PORT=4000
# Render зэрэг host PORT-ыг inject хийвэл түүнийг автоматаар авна (main.ts).

# Frontend origin(ууд) — таслалаар тусгаарлана (CORS + Socket.IO allowlist)
CORS_ORIGINS=http://localhost:3000

# PostgreSQL (Prisma). Render/Neon дээр тухайн сервисийн connection string-ийг тавина.
DATABASE_URL=postgresql://fuel:fuel@localhost:5432/fuel?schema=public

# Redis (session/cache/throttle). Локал Memurai/портабл = redis://localhost:6379;
# Upstash/Render Key Value = rediss://...  (Redis-гүйгээр login/refresh/throttle ажиллахгүй)
REDIS_URL=redis://localhost:6379

# JWT (дор хаяж 8 тэмдэгт; production-д урт random нууц ашигла)
JWT_ACCESS_SECRET=change-me-access-secret-min-8
JWT_REFRESH_SECRET=change-me-refresh-secret-min-8
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Лог
LOG_LEVEL=info
# LOKI_URL=

# И-баримт (хэрэгжээгүй — default унтраалттай)
EBARIMT_ENABLED=false
# EBARIMT_BASE_URL=
# EBARIMT_MERCHANT_TIN=
