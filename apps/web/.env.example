# ── Web (Next.js PWA) — apps/web/.env.local ──
# NEXT_PUBLIC_* нь BUILD үед кодод шигдэнэ — өөрчилбөл web-ийг ДАХИН build/deploy хийнэ.

# API-ийн суурь URL (төгсгөлд /api нэмэгдэнэ). Локал = http://localhost:4000;
# Render/прод = https://<fuel-api>.onrender.com
NEXT_PUBLIC_API_URL=http://localhost:4000
