# ─────────────────────────────────────────────────────────────
# Fuel Retail System — орчны хувьсагч (жишээ)
# Бодит .env-ийг ХЭЗЭЭ Ч git-д оруулахгүй (CLAUDE.md §11)
# ─────────────────────────────────────────────────────────────

# --- Ерөнхий ---
NODE_ENV=development

# --- API (NestJS) ---
API_PORT=4000
# CORS-д зөвшөөрөх frontend origin (таслалаар)
CORS_ORIGINS=http://localhost:3000

# --- Өгөгдлийн сан (PostgreSQL 16 + TimescaleDB) ---
DATABASE_URL=postgresql://fuel:fuel@localhost:5432/fuel?schema=public

# --- Redis (cache / session / rate-limit) ---
REDIS_URL=redis://localhost:6379

# --- Auth (JWT + RBAC) — CLAUDE.md §11 ---
# Production-д ХҮЧТЭЙ, санамсаргүй secret ашиглана (openssl rand -base64 48)
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_REFRESH_SECRET=dev-refresh-secret-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Logging (Pino → Loki) — CLAUDE.md §8 ---
LOG_LEVEL=debug
LOKI_URL=http://localhost:3100

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# --- И-баримт (E-barimt) — CLAUDE.md §12 ---
# ⚠️ Official posapi спецээс авна. Доорх нь зөвхөн placeholder.
EBARIMT_ENABLED=false
EBARIMT_BASE_URL=
EBARIMT_MERCHANT_TIN=
