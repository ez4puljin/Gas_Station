{
  "name": "fuel-retail-system",
  "version": "0.0.0",
  "private": true,
  "description": "2-10 салбартай шатахуун түгээх станцын сүлжээний менежментийн систем",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rimraf node_modules",
    "db:migrate": "pnpm --filter @fuel/api prisma migrate dev",
    "db:generate": "pnpm --filter @fuel/api prisma generate",
    "db:seed": "pnpm --filter @fuel/api prisma db seed",
    "db:studio": "pnpm --filter @fuel/api prisma studio"
  },
  "devDependencies": {
    "prettier": "^3.4.2",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
